{
  "name": "gambiconf",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && touch ./build/.nojekyll && echo \"gambiconf.dev\" > ./build/CNAME",
    "build:prod": "ENV=production npm run build",
    "build:staging": "ENV=staging npm run build",
    "deploy:prod": "gh-pages -d build -r git@github.com:gambiconf/gambiconf.github.io.git -t",
    "deploy:staging": "gh-pages -d build -r git@github.com:gambiconf/website-staging.git -t",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --ignore-path .gitignore --check . && eslint .",
    "format": "prettier --ignore-path .gitignore --write ."
  },
  "dependencies": {
    "@fluent/bundle": "^0.18.0",
    "@fluent/langneg": "^0.7.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "jsdom": "^27.0.0",
    "rough-notation": "^0.5.1",
    "svelte-fa": "^4.0.4",
    "svelte-rough-notation": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@nubolab-ffwd/svelte-fluent": "^1.0.5",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.1.12"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  }
}
